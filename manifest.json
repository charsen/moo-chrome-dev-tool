{
  "manifest_version": 3,
  "minimum_chrome_version": "111",
  "name": "Moo Dev Tool",
  "version": "0.8.1",
  "description": "前后端业务调试工具",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Moo Dev Tool",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "devtools_page": "src/devtools/index.html",
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://moo.placeholder.example/*"],
      "js": ["src/injected/main-world.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://moo.placeholder.example/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "tabs", "scripting", "alarms", "offscreen"],
  "optional_permissions": ["tabCapture"],
  "optional_host_permissions": ["<all_urls>"],
  "commands": {
    "start-recording": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "开始录制当前标签页（tabCapture 需要快捷键 / 扩展图标这类用户手势才能调起）"
    },
    "open-popup": {
      "suggested_key": {
        "default": "Alt+Shift+M",
        "mac": "Alt+Shift+M"
      },
      "description": "打开 Moo 控制面板（toolbar popup，含项目匹配状态 + 录屏开关 + DevTools 跳转提示）"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["assets/*.js", "assets/*.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
