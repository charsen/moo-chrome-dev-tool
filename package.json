{
  "name": "moo-chrome-dev-tool",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "前后端业务调试 Chrome 扩展",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "type-check:tests": "vue-tsc --noEmit -p tsconfig.tests.json",
    "check:versions": "node scripts/check-version-consistency.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "mock": "node scripts/mock-server.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "release": "node scripts/release.mjs",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check:versions && pnpm type-check && pnpm test"
  },
  "dependencies": {
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.263",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^1.6.1",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.0.6"
  }
}
